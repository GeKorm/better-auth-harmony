{
  "name": "@repo/root",
  "type": "module",
  "private": true,
  "version": "",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "yarn@4.13.0",
  "workspaces": [
    "examples/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "examples": "turbo start --concurrency=1 --cache-dir=.turbo --filter=\"@repo/hono-*\" -- --max-warnings=0",
    "stylecheck": "prettier . --check",
    "build": "turbo build --concurrency=100% --cache-dir=.turbo",
    "lint": "turbo run lint lint:root --concurrency=100% --cache-dir=.turbo -- --max-warnings=0",
    "test": "turbo test --cache-dir=.turbo",
    "lint:root": "CHECK_REDOS=true eslint .",
    "emit-types": "turbo run emit-types --concurrency=100% --cache-dir=.turbo",
    "typecheck": "turbo run typecheck --concurrency=100% --cache-dir=.turbo",
    "release": "turbo run build --cache-dir=.turbo && yarn workspaces foreach -A -p -j unlimited --no-private exec npm publish --provenance --tolerate-republish --access public && changeset tag",
    "format": "prettier --write \"**/*.{cjs,js,mjs,ts,tsx,md,json}\""
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@opentelemetry/api": "1.9.1",
    "@repo/eslint-config": "workspace:*",
    "@repo/tsconfig": "workspace:*",
    "changesets-changelog-clean": "^1.3.0",
    "eslint": "^9.39.4",
    "prettier": "^3.8.3",
    "turbo": "2.9.6",
    "typescript": "^6.0.2"
  },
  "dependenciesMeta": {
    "better-sqlite3": {
      "built": true
    },
    "esbuild": {
      "built": true
    },
    "unrs-resolver": {
      "built": true
    }
  }
}
